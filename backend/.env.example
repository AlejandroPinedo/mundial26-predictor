# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mundial26_dev

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Monitoring
SENTRY_DSN=your-sentry-dsn-here

# Resultados en vivo (cron sync-results) — token de football-data.org
FOOTBALL_DATA_TOKEN=your-football-data-org-token

# Secreto compartido para el endpoint POST /cron/sync-results (lo envía el
# pinger externo en "Authorization: Bearer <CRON_SECRET>"). Usa un valor largo y aleatorio.
CRON_SECRET=change-this-to-a-long-random-secret
